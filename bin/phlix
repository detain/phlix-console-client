#!/usr/bin/env php
<?php

declare(strict_types=1);

use Phlix\Console\Api\ApiClient;
use Phlix\Console\App;
use Phlix\Console\Capabilities;
use Phlix\Console\Config\Config;
use Phlix\Console\Config\TokenStore;
use Phlix\Console\Media\MosaicFactory;
use Phlix\Console\Media\PosterLoader;
use Phlix\Console\Spike\PosterSpike;
use Phlix\Console\Spike\VideoSpike;
use Phlix\Console\Store\AuthStore;
use Phlix\Console\Store\LibrariesStore;
use Phlix\Console\Store\MediaStore;
use SugarCraft\Core\Program;
use SugarCraft\Mosaic\DiskCache;

// Locate the Composer autoloader whether we run from the repo or as an
// installed dependency in someone else's vendor/.
foreach ([__DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $autoload) {
    if (is_file($autoload)) {
        require $autoload;
        break;
    }
}
if (!class_exists(Program::class)) {
    fwrite(STDERR, "Phlix: Composer autoloader not found — run `composer install`.\n");
    exit(1);
}

$cmd = $argv[1] ?? 'help';

/** Pull a --mode=… flag out of argv, if present. */
$mode = null;
foreach ($argv as $arg) {
    if (is_string($arg) && str_starts_with($arg, '--mode=')) {
        $mode = substr($arg, 7);
    }
}
$intArg = static fn(int $i, int $default): int =>
    isset($argv[$i]) && ctype_digit((string) $argv[$i]) ? (int) $argv[$i] : $default;

try {
    switch ($cmd) {
        case 'doctor':
            echo (new Capabilities())->report(), "\n";
            break;

        case 'poster':
            $path = $argv[2] ?? null;
            if ($path === null) {
                fwrite(STDERR, "usage: phlix poster <image> [width] [height] [--mode=auto|halfblock|quarterblock|ascii|ansi256|truecolor|sixel|kitty|iterm2]\n");
                exit(2);
            }
            echo (new PosterSpike())->render($path, $intArg(3, 40), isset($argv[4]) && ctype_digit((string) $argv[4]) ? (int) $argv[4] : null, $mode), "\n";
            break;

        case 'frame':
            $src = $argv[2] ?? null;
            if ($src === null) {
                fwrite(STDERR, "usage: phlix frame <video|gif> [count] [cols] [rows] [--mode=auto|halfblock|sixel|kitty|ascii]\n");
                exit(2);
            }
            $spike = new VideoSpike();
            echo $spike->probeReport($src), "\n";
            foreach ($spike->frames($src, $intArg(3, 1), $intArg(4, 60), $intArg(5, 20), $mode) as $i => $ansi) {
                echo "--- frame {$i} ---\n", $ansi, "\n";
            }
            break;

        case 'run':
            $config = Config::load();
            $api = new ApiClient($config->serverUrl ?? '');
            $auth = new AuthStore($api, TokenStore::default());
            $libraries = new LibrariesStore($api);
            $media = new MediaStore($api);
            // Cell modes (half/quarter-block, ascii/ansi256/truecolor) tile as text;
            // graphics modes (sixel/kitty/iterm2) tile as an out-of-band overlay —
            // PosterLoader returns a marker block and the runtime paints the blob.
            // PosterLoader keys its cache by the mosaic's protocol(), so each mode
            // caches separately.
            [$mosaic, $overlay] = MosaicFactory::forPosterGrid($mode);
            $posters = new PosterLoader($mosaic, new DiskCache(Config::dir() . '/posters'), $overlay);
            (new Program(App::boot($config, $auth, $api, $libraries, $media, $posters)))->run();
            break;

        case 'help':
        default:
            fwrite(STDOUT, <<<TXT
phlix — Phlix console client (Phase 0 spike)

usage:
  phlix doctor                              report terminal graphics capabilities
  phlix poster <image> [w] [h]              render an image at a cell size
  phlix frame  <video|gif> [n] [cols] [rows]  decode N frames to ANSI
  phlix run [--mode=…]                      launch the full-window app (needs a TTY)

flags:
  --mode=<mode>   force a render mode (posters are cached per mode)

render modes:
  cell modes (tile in the poster grid):
    halfblock     24-bit colour half-block (▀) — the default / "ansi" mode
    quarterblock  denser colour blocks (▘▝▖▗)
    ascii         monochrome character ramp
    ansi256       256-colour character ramp
    truecolor     24-bit-colour character ramp
  graphics modes (real images; tiled in the grid as an overlay):
    sixel | kitty | iterm2
  auto            inline half-block (default; pass --mode=sixel for graphics)

TXT);
            break;
    }
} catch (\Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . "\n");
    exit(1);
}
